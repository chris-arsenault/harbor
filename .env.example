IMAGE_TAG=local

OANDA_ENV=practice
ALLOW_LIVE=false
OANDA_API_KEY=replace-with-practice-token
OANDA_API_TOKEN=replace-with-practice-token
OANDA_ACCOUNT_ID=replace-with-practice-account-id
OANDA_BOOK_RECORDER_ENABLED=true
OANDA_BOOK_POLL_INTERVAL_SECONDS=300

DB_HOST=192.168.66.3
DB_PORT=5432
DB_USER=harbor_app
DB_PASSWORD=replace-with-database-password
DB_NAME=harbor

HARBOR_AUTH_REQUIRED=true
HARBOR_AUTH_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/replace-with-user-pool-id
HARBOR_AUTH_CLIENT_ID=replace-with-harbor-app-client-id
HARBOR_COGNITO_USER_POOL_ID=replace-with-user-pool-id
HARBOR_COGNITO_CLIENT_ID=replace-with-harbor-app-client-id

NTFY_URL=
